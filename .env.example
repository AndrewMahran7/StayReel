# Copy to .env and fill in real values.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat public SDK keys (from RevenueCat dashboard → API Keys)
# Production: iOS starts with "appl_", Android starts with "goog_"
# Test/sandbox: starts with "test_" (works for both platforms)
EXPO_PUBLIC_RC_API_KEY_IOS=appl_your_ios_key_here
EXPO_PUBLIC_RC_API_KEY_ANDROID=goog_your_android_key_here
