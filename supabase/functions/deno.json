{
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "importMap": "./import_map.json",
  "lint": {
    "rules": {
      "include": ["no-unused-vars", "no-explicit-any", "eqeqeq"]
    }
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": false
  }
}
